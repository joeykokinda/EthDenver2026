# ==============================================================================
# HEDERA TESTNET CREDENTIALS
# ==============================================================================

# Your Hedera testnet deployer private key (converted from DER format to 0x...)
# Get from: https://portal.hedera.com → Create testnet account
# Convert using: npm run setup:convert-key
DEPLOYER_PRIVATE_KEY=0x...

# Optional: If you want to manually register an agent with specific key
# Otherwise agents auto-generate wallets in agents/.wallets/
AGENT_ALPHA_PRIVATE_KEY=0x...

# ==============================================================================
# DEPLOYED CONTRACT ADDRESSES (Already deployed for you!)
# ==============================================================================

# AgentIdentity contract (registration + reputation)
AGENT_IDENTITY_CONTRACT=0x0874571bAfe20fC5F36759d3DD3A6AD44e428250

# AgentMarketplace contract (jobs + bidding + escrow)
AGENT_MARKETPLACE_CONTRACT=0x46e12242aEa85a1fa2EA5C769cd600fA64A434C6

# ==============================================================================
# AI/LLM API KEY (Required for agent decisions)
# ==============================================================================

# OpenAI API Key - Get from: https://platform.openai.com/api-keys
# Cost: ~$0.05 for entire demo (uses gpt-4o-mini)
# If you don't have one, create account at platform.openai.com
OPENAI_API_KEY=sk-proj-...

# ==============================================================================
# ORCHESTRATOR SETTINGS (Agent engine)
# ==============================================================================

# Port for orchestrator API (activity feed)
ORCHESTRATOR_PORT=3001

# ==============================================================================
# FRONTEND SETTINGS (Next.js env vars)
# ==============================================================================

# Contract addresses for frontend to read blockchain data
NEXT_PUBLIC_CONTRACT_ADDRESS=0x0874571bAfe20fC5F36759d3DD3A6AD44e428250
NEXT_PUBLIC_MARKETPLACE_ADDRESS=0x46e12242aEa85a1fa2EA5C769cd600fA64A434C6

# Activity feed API URL
# Local development: http://localhost:3001
# Production: https://api.agenttrust.life
NEXT_PUBLIC_ACTIVITY_API=http://localhost:3001

# ==============================================================================
# QUICK START
# ==============================================================================
#
# 1. Copy this file: cp .env.example .env
# 2. Add your OPENAI_API_KEY (only required env var!)
# 3. (Optional) Add DEPLOYER_PRIVATE_KEY if deploying new contracts
# 4. Run: npm run orchestrator
# 5. In another terminal: npm run dev:app
# 6. Visit: http://localhost:3000/live
#
# ==============================================================================
